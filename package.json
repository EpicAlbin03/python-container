{
  "name": "python-container",
  "private": true,
  "scripts": {
    "docker:watch": "docker compose up --watch",
    "docker:up": "docker compose up -d",
    "docker:build": "docker compose up --build -d",
    "docker:prod": "docker compose -f docker-compose.yml up -d",
    "docker:build:prod": "docker compose -f docker-compose.yml up --build -d",
    "docker:down": "docker compose down",
    "docker:remove": "docker compose down -v",
    "export:requirements": "uv export --format requirements-txt --no-hashes --no-dev > requirements.txt"
  },
  "dependencies": {}
}
